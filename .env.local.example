# Google Maps JavaScript API (required for interactive map on the Locations page)
# 1. Google Cloud Console → APIs & Services → Enable:
#    - Maps JavaScript API
#    - Geocoding API (refines the Annandale office pin)
# 2. Billing must be enabled on the project
# 3. Create an API key → Application restrictions → HTTP referrers:
#    - http://localhost:3000/*
#    - http://127.0.0.1:3000/*
#    - https://your-production-domain.com/*
# 4. API restrictions → Restrict key → select Maps JavaScript API + Geocoding API
# 5. Copy this file to .env.local and paste your key below
# 6. Restart the dev server: npm run dev
#
# Use NEXT_PUBLIC_* for the browser map (required). GOOGLE_MAPS_API_KEY is mirrored
# automatically when NEXT_PUBLIC_GOOGLE_MAPS_API_KEY is unset.

NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_API_KEY_HERE
# GOOGLE_MAPS_API_KEY=YOUR_API_KEY_HERE

# ============================================================
# Intake form secure backend (required for POST /api/intake)
# ============================================================
# 32-byte encryption key — use 64 hex characters or a long random secret (32+ chars).
# Generate: openssl rand -hex 32
INTAKE_ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHARACTERS_OR_LONG_RANDOM_SECRET

# Encrypted intake storage directory (relative to project root or absolute path)
INTAKE_STORAGE_PATH=./storage/intake

# Optional max upload limits (bytes)
INTAKE_MAX_FILE_BYTES=10485760
INTAKE_MAX_TOTAL_BYTES=52428800

# Optional database URL for non-PHI submission index only (confirmation ID, timestamps)
# Full PHI remains in encrypted files unless you implement a HIPAA-ready DB layer.
DATABASE_URL=

# Staff notification email via Resend — https://resend.com
# Required for intake team email copies of each submission.
RESEND_API_KEY=
INTAKE_STAFF_NOTIFICATION_EMAIL=intake@edenabatherapy.com
INTAKE_NOTIFICATION_FROM_EMAIL=notifications@edenabatherapy.com

# ============================================================
# Intake delivery — Google Sheets (required for spreadsheet logging)
# Full setup: docs/google-sheets-service-account-setup.md
# ============================================================
# Auth priority: env_private_key → json_key → adc (Application Default Credentials)
#
# Option A — ADC (no JSON key; works when iam.disableServiceAccountKeyCreation is enforced):
#   gcloud auth application-default login --scopes=https://www.googleapis.com/auth/spreadsheets
#   Your Google account must have Editor access to the spreadsheet.
#
# Option B — JSON key → secrets/google-sheets-service-account.json
# Option C — GOOGLE_SERVICE_ACCOUNT_EMAIL + GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY
#
# Create a tab named "Intake Submissions" with this header row:
#    Submission Date and Time | Parent Name | Child Name | Age | Diagnosis Status |
#    State | City | Service Type | Goals | Insurance Provider | Phone Number |
#    Email Address | Preferred Contact Method | Confirmation ID | Source
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_TAB_NAME=Intake Submissions
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=secrets/google-sheets-service-account.json
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# GOOGLE_APPLICATION_CREDENTIALS=

# Optional object storage credentials (future S3-compatible encrypted upload target)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1

# ============================================================
# Google reCAPTCHA v2 Checkbox (protects public forms)
# ============================================================
# Register a reCAPTCHA v2 "I'm not a robot" Checkbox key at
# https://www.google.com/recaptcha/admin
# Add localhost and edenabatherapy.com to allowed domains.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ============================================================
# Eden ABA Therapy assistant (OpenAI Responses API)
# ============================================================
# Server-only. Never expose OPENAI_API_KEY in the browser.
# Create a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Published OpenAI prompt ID for the Eden assistant (optional override)
OPENAI_EDEN_PROMPT_ID=pmpt_6a2ab01ec1908197b18a5fab8fab0cd700b0eed15d55e43d

# ============================================================
# Medicaid insurance verification (POST /api/insurance/verify)
# ============================================================
# Allowed values: manual | clearinghouse | mes_provider_api
# Default: manual (returns Pending Staff Review until staff verifies)
MEDICAID_VERIFICATION_MODE=manual

# Set to true only after verifyWithClearinghouse() or verifyWithMesProviderApi() is fully implemented
# AND approved credentials are configured above.
# MEDICAID_LIVE_VERIFICATION_ENABLED=true

# Live eligibility API
# Vendor: availity (Availity OAuth) | standard | clearinghouse_legacy (generic REST)
ELIGIBILITY_VENDOR=standard

# --- Availity (set ELIGIBILITY_VENDOR=availity) ---
# From Availity Developer Portal → My Apps → App Details
ELIGIBILITY_API_CLIENT_ID=
ELIGIBILITY_API_CLIENT_SECRET=
# Defaults: https://api.availity.com/v1/token and https://api.availity.com
# ELIGIBILITY_TOKEN_URL=https://api.availity.com/v1/token
# ELIGIBILITY_API_BASE_URL=https://api.availity.com
# ELIGIBILITY_AVAILITY_SCOPE=
# ELIGIBILITY_AVAILITY_POLL_INTERVAL_MS=1500
# ELIGIBILITY_AVAILITY_POLL_MAX_MS=25000

# --- Generic REST clearinghouse (standard / clearinghouse_legacy) ---
# ELIGIBILITY_* takes precedence; falls back to CLEARINGHOUSE_* when unset.
ELIGIBILITY_API_URL=
ELIGIBILITY_API_KEY=

# Eden provider NPI sent on eligibility inquiries (required for live checks)
ELIGIBILITY_PROVIDER_NPI=
# Optional JSON map: {"Display Name":"PAYER_ID"}
# ELIGIBILITY_PAYER_ID_MAP=
# Fallback payer ID when insurance provider name is unmapped
# ELIGIBILITY_DEFAULT_PAYER_ID=
# Default patient state for Availity requests (default: VA)
# ELIGIBILITY_DEFAULT_PATIENT_STATE=VA
# Portal live check (default: on when credentials exist). Set false to always use stored status.
# ELIGIBILITY_PORTAL_LIVE_ENABLED=true

# Clearinghouse adapter (when MEDICAID_VERIFICATION_MODE=clearinghouse)
# Used as fallback when ELIGIBILITY_API_URL / ELIGIBILITY_API_KEY are unset
CLEARINGHOUSE_API_URL=
CLEARINGHOUSE_API_KEY=

# Virginia Medicaid MES Provider API adapter (when MEDICAID_VERIFICATION_MODE=mes_provider_api)
MES_PROVIDER_API_URL=
MES_PROVIDER_CLIENT_ID=
MES_PROVIDER_CLIENT_SECRET=

# Encrypted verification request storage (uses INTAKE_ENCRYPTION_KEY if INSURANCE_ENCRYPTION_KEY unset)
INSURANCE_ENCRYPTION_KEY=
INSURANCE_STORAGE_PATH=./storage/insurance

# Staff admin token for /admin/insurance-verifications (min 32 characters)
# Generate: openssl rand -hex 32
INSURANCE_STAFF_ADMIN_TOKEN=

# Admin session TTL in seconds (default 28800 = 8 hours)
# INSURANCE_ADMIN_SESSION_TTL_SECONDS=28800

# Family portal session TTL after identity verification (default 7200 = 2 hours)
# INSURANCE_PORTAL_SESSION_TTL_SECONDS=7200

# Portal identity verify rate limits (failures only — successful verify clears counters)
# In development, limits are relaxed automatically (no lockout).
# INSURANCE_PORTAL_VERIFY_RELAXED=true
# INSURANCE_PORTAL_VERIFY_MAX_FAILURES=5
# INSURANCE_PORTAL_VERIFY_LOCK_MS=1800000
# INSURANCE_PORTAL_VERIFY_HOURLY_MAX=30

# Dedicated secret for portal session signing (recommended in production)
# INSURANCE_PORTAL_SESSION_SECRET=

# Enable PHI-free CSV export for authorized admins
# INSURANCE_EXPORT_ENABLED=true

# Staff notifications on new verification requests (PHI-free)
# Channels: email | slack | both
INSURANCE_NOTIFICATION_CHANNELS=email
INSURANCE_STAFF_NOTIFICATION_EMAIL=
INSURANCE_NOTIFICATION_FROM_EMAIL=
INSURANCE_SLACK_WEBHOOK_URL=

# Live verification — keep false until clearinghouse/MES UAT is complete
MEDICAID_LIVE_VERIFICATION_ENABLED=false

# Clearinghouse adapter tuning (optional)
# CLEARINGHOUSE_TIMEOUT_MS=30000
# CLEARINGHOUSE_MAX_RETRIES=3
# CLEARINGHOUSE_RETRY_DELAY_MS=1000
